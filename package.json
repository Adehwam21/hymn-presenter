{
  "name": "nhuc-hymns-projector",
  "version": "1.0.0",
  "description": "Methodist Hymn Projector built for New Hope Universal Church (NHUC)",
  "author": {"name": "Aaron Katey Kudadjie", "github": "Adehwam@21"},
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "sql.js": "^1.11.0"
  },
  "build": {
    "appId": "com.nhuc.hymnprojector",
    "productName": "NHUC Hymn Projector",
    "icon": "assets/icons/logo-transparent.ico",
    "extraResources": [
    {
      "from": "data/mhb_clean.db",
      "to": "mhb_clean.db"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icons/logo-transparent.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/icons/logo-transparent.icns"
  },
  "files": [
    "**/*",
    "!node_modules/electron*"
  ]
  }
}
